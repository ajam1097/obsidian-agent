{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/page-kinds/system.schema.json",
  "title": "System Page",
  "description": "Current-state description of a setup or workflow surface.",
  "x-vault": {
    "kind": "system",
    "folder": "systems",
    "filename": "{name}.md"
  },
  "type": "object",
  "additionalProperties": false,
  "required": ["type", "status", "created", "updated"],
  "properties": {
    "type": {
      "x-group": "identity",
      "const": "system",
      "default": "system"
    },
    "domains": {
      "x-group": "classification",
      "type": "array",
      "items": { "type": "string" },
      "x-vocabulary": "domains"
    },
    "status": {
      "x-group": "lifecycle",
      "enum": ["active", "archived"],
      "default": "active"
    },
    "created": {
      "x-group": "metadata",
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "updated": {
      "x-group": "metadata",
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    }
  }
}

