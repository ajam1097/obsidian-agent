{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/page-kinds/source.schema.json",
  "title": "Source Page",
  "description": "Captured external material waiting to be processed into knowledge.",
  "x-vault": {
    "kind": "source",
    "folder": "sources",
    "filename": "{name}.md"
  },
  "type": "object",
  "additionalProperties": false,
  "required": ["type", "processing_status", "created"],
  "properties": {
    "type": {
      "x-group": "identity",
      "const": "source",
      "default": "source"
    },
    "source_type": {
      "x-group": "classification",
      "enum": ["article", "book", "conversation", "video", "other"],
      "default": "other"
    },
    "source_url": {
      "x-group": "relationships",
      "type": ["string", "null"]
    },
    "processing_status": {
      "x-group": "lifecycle",
      "enum": ["unprocessed", "processed", "skipped"],
      "default": "unprocessed"
    },
    "created": {
      "x-group": "metadata",
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    }
  }
}

