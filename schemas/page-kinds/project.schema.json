{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/page-kinds/project.schema.json",
  "title": "Project Page",
  "description": "A committed outcome that needs coordinated work.",
  "x-vault": {
    "kind": "project",
    "folder": "efforts/projects",
    "filename": "{name}.md"
  },
  "type": "object",
  "additionalProperties": false,
  "required": ["type", "status", "outcome", "created", "updated"],
  "properties": {
    "type": {
      "x-group": "identity",
      "const": "project",
      "default": "project"
    },
    "outcome": {
      "x-group": "classification",
      "type": "string"
    },
    "domains": {
      "x-group": "classification",
      "type": "array",
      "items": { "type": "string" },
      "x-vocabulary": "domains"
    },
    "status": {
      "x-group": "lifecycle",
      "enum": ["active", "backlog", "waiting", "archived"],
      "default": "backlog"
    },
    "task_project": {
      "x-group": "relationships",
      "description": "Optional link or id for the matching task-manager project.",
      "type": ["string", "null"]
    },
    "repo": {
      "x-group": "relationships",
      "type": ["string", "null"]
    },
    "plan_path": {
      "x-group": "relationships",
      "type": ["string", "null"]
    },
    "created": {
      "x-group": "metadata",
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "updated": {
      "x-group": "metadata",
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    }
  }
}

